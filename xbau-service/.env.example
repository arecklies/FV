# XBau-Service Umgebungsvariablen
# Kopieren nach .env und Werte ausfuellen

# Supabase-Verbindung (gleiche Instanz wie Fachverfahren)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Webhook-Authentifizierung (HMAC-SHA256)
# Gleicher Wert wie XBAU_WEBHOOK_SECRET im Fachverfahren
WEBHOOK_SECRET=your-shared-secret-min-32-chars

# Fachverfahren-URL fuer Webhook-Callbacks
FACHVERFAHREN_URL=https://your-fachverfahren.vercel.app

# Worker-Konfiguration
POLL_INTERVAL_MS=5000
